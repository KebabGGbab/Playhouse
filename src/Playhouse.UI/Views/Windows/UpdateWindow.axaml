<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="using:KebabGGbab.Avalonia.Extensions.Controls"
        xmlns:vm="using:Playhouse.ViewModels.ViewModels"
        xmlns:userControls="using:Playhouse.UI.Views.UserControls"
        x:Class="Playhouse.UI.Views.Windows.UpdateWindow" x:FieldModifier="internal"
        x:DataType="vm:UpdateViewModel"
        mc:Ignorable="d"
        Width="330" Height="420"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True" WindowDecorations="BorderOnly"
        CanResize="False">

        <Grid RowDefinitions="3*,*">
        <Grid Grid.Row="0"
              RowDefinitions="*">

            <userControls:IconLoaderView />

        </Grid>

        <controls:LinearBubbleLoader Grid.Row="1" />

    </Grid>

</Window>
