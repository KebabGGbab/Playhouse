<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="using:Avalonia.Xaml.Interactivity"
        xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
        xmlns:vm="using:Playhouse.ViewModels.ViewModels"
        xmlns:views="using:Playhouse.UI.Views"
        xmlns:models="using:Playhouse.Core.Models"
        xmlns:l="https://github.com/KebabGGbab"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Playhouse.UI.Views.Windows.MainWindow" x:FieldModifier="internal"
        Icon="{StaticResource ApplicationIcon}"
        Title="{l:Localization WindowMainTitle}"
        x:Name="Window"
        x:DataType="vm:MainWindowViewModel"
        d:DesignWidth="1920" d:DesignHeight="1080"
        Loaded="Window_Loaded">

    <TabControl Classes="middle" 
                TabStripPlacement="Left" 
                SelectedIndex="0">
		<TabItem Theme="{StaticResource Minimalism}">
			<TabItem.Header>
				<TextBlock Text="{l:Localization TabRunHeader}" />
            </TabItem.Header>
            <DockPanel MinWidth="1000" 
                       Margin="10"
                       LastChildFill="True">
                <HeaderedContentControl Classes="groupbox centered-header"
                                        DockPanel.Dock="Right" 
                                        MinWidth="400" MaxWidth="500"
                                        Header="{l:Localization BoxRunningTasksHeader}">
					<ScrollViewer>
						<StackPanel>
							<ItemsControl ItemsSource="{Binding Path=RunViewModel.RunningTasks}" />
                        </StackPanel>
                    </ScrollViewer>
                </HeaderedContentControl>
                <HeaderedContentControl Classes="groupbox centered-header" 
                                        MinWidth="300" MaxWidth="500"
                                        VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Header="{l:Localization BoxRunTaskHeader}">
					<Grid Grid.IsSharedSizeScope="True" RowDefinitions="auto,auto,200,auto" ColumnSpacing="15" RowSpacing="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition SharedSizeGroup="Profiles" />
                            <ColumnDefinition SharedSizeGroup="Profiles" />
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0" Grid.Row="0"
                               Classes="inline"
                               VerticalAlignment="Center"
                               Target="{Binding ElementName=ComboBoxSelectBotRun}"
                               Content="{l:Localization LabelSelectBot}" />

                        <ComboBox x:Name="ComboBoxSelectBotRun"
                                  Grid.Column="1" Grid.Row="0"
                                  Classes="inline, editable"
                                  MinWidth="150" MaxWidth="300"
                                  ItemsSource="{Binding Path=BotsViewModel.Bots}"
                                  SelectedItem="{Binding Path=RunViewModel.SelectedBotStart}"
                                  DisplayMemberBinding="{Binding Path=Name}" />

                        <TextBlock Grid.Column="0" Grid.Row="1"
                                   Text="{l:Localization LabelSelectProfiles}" />

                        <ListBox Grid.Column="0" Grid.Row="2"
                                 ItemsSource="{Binding Path=RunViewModel.UnselectedProfiles}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Path=Name}" 
                                            Command="{Binding $parent[Window].DataContext.RunViewModel.SelectProfileCommand}"
                                            CommandParameter="{Binding .}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListBox Grid.Column="1" Grid.Row="2"
                                 ItemsSource="{Binding Path=RunViewModel.SelectedProfiles}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Path=Name}"
                                            Command="{Binding $parent[Window].DataContext.RunViewModel.ExcludeProfileCommand}"
                                            CommandParameter="{Binding .}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Grid.ColumnSpan="2" Grid.Row="3"
                                Classes="box-action"
                                Content="{l:Localization ButtonStart}"
                                Command="{Binding Path=RunViewModel.RunBotCommand}" />
                    </Grid>
                </HeaderedContentControl>
            </DockPanel>
        </TabItem>

        <!-- Таба ботов -->

        <TabItem x:Name="BotsTab" 
                 Theme="{StaticResource Minimalism}">
			<TabItem.Header>
				<TextBlock Text="{l:Localization TabBotsHeader}" />
            </TabItem.Header>
            <i:Interaction.Behaviors>
				<ia:EventTriggerBehavior EventName="Loaded" SourceObject="{Binding ElementName=BotsTab}">
					<ia:InvokeCommandAction Command="{Binding Path=BotsViewModel.LoadDataCommand}" />
                </ia:EventTriggerBehavior>
            </i:Interaction.Behaviors>
            <Grid ColumnDefinitions="*, auto"
                  Margin="10">
                <WrapPanel Grid.Column="0"
                           Classes="model-settings-container">

					<HeaderedContentControl Classes="groupbox centered-header model-settings-box"
                                            Header="{l:Localization BoxCreateBotHeader}">
                        <StackPanel Orientation="Vertical">
                            
                            <StackPanel Classes="first-group">
							    <Label Classes="overline"
                                       Target="ComboBoxBotsCreateSelectProfile"
                                       Content="{l:Localization LabelSelectProfile}" />
                                <ComboBox x:Name="ComboBoxBotsCreateSelectProfile"
                                          Classes="editable"
                                          ItemsSource="{Binding Path=BotsViewModel.Profiles}"
                                          SelectedItem="{Binding Path=BotsViewModel.SelectedProfileCreate}"
                                          DisplayMemberBinding="{Binding Path=Name}"
                                          Text="{Binding Path=BotsViewModel.ProfileNameFilterForCreateBot}" />
                            </StackPanel>

                            <StackPanel Classes="middle-group">
                                <Label Classes="overline" 
                                       Target="TextBoxBotsCreateName"
                                       Content="{l:Localization LabelBotName}" />
                                <TextBox x:Name="TextBoxBotsCreateName" 
                                         Text="{Binding Path=BotsViewModel.BotNameCreate}" />
                            </StackPanel>

                            <StackPanel Classes="last-group">
                                <Label Classes="overline" 
                                       Target="ComboBoxBotsCreateBrowserType"
                                       Content="{l:Localization LabelSelectBrowser}" />
                                <ComboBox x:Name="ComboBoxBotsCreateBrowserType"
                                          ItemsSource="{Binding Path=BotsViewModel.Browsers}"
                                          SelectedItem="{Binding Path=BotsViewModel.SelectedBrowserType}" />
                            </StackPanel>

                            <Button Classes="box-action"
                                    Content="{l:Localization ButtonCreate}"
                                    Command="{Binding Path=BotsViewModel.CreateBotCommand}" />
                       
                        </StackPanel>
                    </HeaderedContentControl>

                    <HeaderedContentControl Classes="groupbox centered-header model-settings-box"
                                            Header="{l:Localization BoxDeleteBotHeader}">
						<StackPanel Orientation="Vertical">
                            
                            <StackPanel Classes="first-group">
							    <Label Classes="overline"
                                       Target="ComboBoxBotDeleteSelectBot"
                                       Content="{l:Localization LabelSelectBot}" />
                                <ComboBox x:Name="ComboBoxBotDeleteSelectBot"
                                          Classes="editable"
                                          ItemsSource="{Binding Path=BotsViewModel.BotsDelete}"
                                          SelectedItem="{Binding Path=BotsViewModel.SelectedBotDelete}"
                                          DisplayMemberBinding="{Binding Path=Name}"
                                          Text="{Binding Path=BotsViewModel.BotNameFilterForDelete}" />
                            </StackPanel>

                            <CheckBox Margin="0,10,0,0"
                                      Content="{l:Localization CheckBoxConfirm}" />
                            <Button Classes="box-action" 
                                    Content="{l:Localization ButtonDelete}"
                                    Command="{Binding Path=BotsViewModel.DeleteBotCommand}" />
                        
                        </StackPanel>
                    </HeaderedContentControl>
                </WrapPanel>

			    <DataGrid Grid.Column="1"
                                MinWidth="100" MaxWidth="400"
                                ItemsSource="{Binding Path=BotsViewModel.Bots}">
				    <DataGrid.Columns>
					    <DataGridTextColumn x:DataType="models:BotConfiguration" 
                                            Width="SizeToHeader"
                                            Header="{l:Localization BotPropertyID}" 
                                            Binding="{Binding Path=Id}" />
                        <DataGridTextColumn x:DataType="models:BotConfiguration" 
                                            Width="*"
                                            Header="{l:Localization BotPropertyName}" 
                                            Binding="{Binding Path=Name}" />
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </TabItem>

        <!-- Таба профилей -->

        <TabItem x:Name="TabProfiles" 
                 Theme="{StaticResource Minimalism}">
			<TabItem.Header>
				<TextBlock Text="{l:Localization TabProfilesHeader}" />
            </TabItem.Header>
            <i:Interaction.Behaviors>
				<ia:EventTriggerBehavior EventName="Loaded" SourceObject="{Binding ElementName=TabProfiles}">
					<ia:InvokeCommandAction Command="{Binding Path=BrowsersViewModel.LoadDataCommand}" />
                </ia:EventTriggerBehavior>
            </i:Interaction.Behaviors>
            <DockPanel LastChildFill="True"
                       HorizontalSpacing="10" VerticalSpacing="10">

                <Border DockPanel.Dock="Bottom"
                        Padding="8 5 8 5"
                        Background="{StaticResource StatusBackground}">
					<DockPanel HorizontalSpacing="25">
					    <StackPanel DockPanel.Dock="Left" 
                                    Orientation="Horizontal">
						    <TextBlock Text="{l:Localization LabelStatusNumberOfProfiles}" />
                            <TextBlock Text="{Binding Path=BrowsersViewModel.Profiles.Count}" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Left" 
                                    Orientation="Horizontal">
						    <TextBlock Text="{l:Localization LabelStatusSelectedProfile}" />
                            <TextBlock Text="{Binding Path=BrowsersViewModel.SelectedProfile.Name}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <HeaderedContentControl DockPanel.Dock="Right"
                                        Classes="groupbox"
                                        Margin="0, 8, 8, 0"
                                        MinWidth="100" MaxWidth="400">
                    <Grid RowDefinitions="*, auto, auto"
                          RowSpacing="10">

					    <DataGrid Grid.Row="0"
                                  ItemsSource="{Binding Path=BrowsersViewModel.Profiles}"
                                  SelectedItem="{Binding Path=BrowsersViewModel.SelectedProfile}">
						    <DataGrid.Columns>
							    <DataGridTextColumn x:DataType="models:BrowserConfiguration"
                                                    Width="SizeToHeader"
                                                    Binding="{Binding Path=Id}"
                                                    Header="{l:Localization ProfilePropertyID}" />
                                <DataGridTextColumn x:DataType="models:BrowserConfiguration" 
                                                    Width="*"
                                                    Binding="{Binding Path=Name}"
                                                    Header="{l:Localization ProfilePropertyName}" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBox Grid.Row="1"
                                 PlaceholderText="{l:Localization TextBoxWatermarkProfilesFilter}" />

                        <Grid Grid.Row="2"
                              RowDefinitions="*,*" ColumnDefinitions="*,*,*"
                              ColumnSpacing="5" RowSpacing="5">

                            <Button Grid.Row="0" Grid.Column="0"
                                    Classes="not-defined-size"
                                    Content="{l:Localization ButtonAdd}"
                                    Command="{Binding Path=BrowsersViewModel.AddProfileCommand}" />
                            <Button Grid.Row="0" Grid.Column="1"
                                    Classes="not-defined-size"
                                    Content="{l:Localization ButtonSave}"
                                    Command="{Binding Path=BrowsersViewModel.SaveProfileCommand}" CommandParameter="{Binding Path=BrowsersViewModel.SelectedProfile}" />
                            <Button Grid.Row="0" Grid.Column="2"
                                    Classes="not-defined-size"
                                    Content="{l:Localization ButtonDelete}"
                                    Command="{Binding Path=BrowsersViewModel.DeleteProfileCommand}" CommandParameter="{Binding Path=BrowsersViewModel.SelectedProfile}" />
                            <Button Grid.Row="1" Grid.Column="1"
                                    Classes="not-defined-size"
                                    Content="{l:Localization ButtonSaveAll}"
                                    Command="{Binding Path=BrowsersViewModel.SaveAllProfilesCommand}" />
                            <Button Grid.Row="2" Grid.Column="2"
                                    Classes="not-defined-size"
                                    Content="{l:Localization ButtonCancel}"
                                    Command="{Binding Path=BrowsersViewModel.CancelProfileChangesCommand}" CommandParameter="{Binding Path=BrowsersViewModel.SelectedProfile}" />
                        </Grid>
                    </Grid>
                </HeaderedContentControl>
				<ScrollViewer Margin="8, 8, 0, 0" 
                              VerticalScrollBarVisibility="Disabled">
					<WrapPanel Classes="model-settings-container">
						<HeaderedContentControl Classes="groupbox centered-header model-settings-box" 
                                                Header="{l:Localization BoxInformationProfileHeader}">
                            <StackPanel Orientation="Vertical">
                                <StackPanel Classes="first-group">
								    <Label Classes="overline" 
                                           Target="{Binding ElementName=TextBoxProfilesInformationName}" 
                                           Content="{l:Localization LabelProfileName}" />
                                    <TextBox x:Name="TextBoxProfilesInformationName"
                                             Text="{Binding Path=BrowsersViewModel.SelectedProfile.Name}" />
                                </StackPanel>
                            </StackPanel>
                        </HeaderedContentControl>
                        <HeaderedContentControl Classes="groupbox centered-header model-settings-box"
                                                Header="{l:Localization BoxStorageProfileHeader}">
                            <StackPanel Orientation="Vertical">
                                <StackPanel Classes="first-group">
							        <Label Classes="overline" 
                                           Target="{Binding ElementName=TextBoxProfilesPathDownloads}" 
                                           Content="{l:Localization LabelDownloadPath}" />
                                    <TextBox x:Name="TextBoxProfilesPathDownloads"
                                             Text="{Binding Path=BrowsersViewModel.SelectedProfile.DownloadsPath}" />
                                </StackPanel>
                                <CheckBox Margin="0,10,0,0"
                                          IsChecked="{Binding Path=BrowsersViewModel.SelectedProfile.AcceptDownloads}"
                                          Content="{l:Localization LabelAcceptDownloadsProfile}" />
                            </StackPanel>
                        </HeaderedContentControl>
                        <HeaderedContentControl Classes="groupbox centered-header model-settings-box"
                                                Header="{l:Localization BoxOtherProfileHeader}">
                            <StackPanel>
						        <CheckBox Margin="0,10,0,0"
                                          Content="{l:Localization CheckBoxHeadlessMode}"
                                          IsChecked="{Binding Path=BrowsersViewModel.SelectedProfile.Headless}" />
                                <CheckBox Margin="0,10,0,10"
                                          Content="{l:Localization CheckBoxEnableChromiumSandbox}"
                                          IsChecked="{Binding Path=BrowsersViewModel.SelectedProfile.ChromiumSandbox}" />
                                <StackPanel Classes="last-group">
                                    <Label Classes="overline" 
                                           Target="{Binding ElementName=NumericUpDownProfilesSlowMo}" 
                                           Content="{l:Localization LabelSlowMo}" />
                                    <NumericUpDown x:Name="NumericUpDownProfilesSlowMo" 
                                                   Text="{Binding Path=BrowsersViewModel.SelectedProfile.SlowMo}" />								
                                </StackPanel>
                            </StackPanel>
                        </HeaderedContentControl>
                    </WrapPanel>
                </ScrollViewer>
            </DockPanel>
        </TabItem>

        <!-- Таба настроек -->

        <TabItem x:Name="TabSettings"
                 Theme="{StaticResource Minimalism}">
			<TabItem.Header>
				<TextBlock Text="{l:Localization TabSettingsHeader}" />
            </TabItem.Header>
            <ScrollViewer HorizontalScrollBarVisibility="Hidden">
                <StackPanel Orientation="Vertical"
                            Grid.IsSharedSizeScope="True">

                    <!-- Данные -->

                    <HeaderedContentControl Classes="settings-group">
                        <HeaderedContentControl.Header>
							<TextBlock Text="{l:Localization MainWindow_TabSettings_DataHeader}"
                                       Classes="settings-group-header" />
                        </HeaderedContentControl.Header>

						<StackPanel Classes="settings-body">

                            <StackPanel>
								<TextBlock Text="{l:Localization MainWindow_TabSettings_DataPath}"
                                       Classes="settings-group-description" />
                                <DockPanel Classes="settings-group-box-items">
                                    <Button DockPanel.Dock="Right"
                                            Classes="settings-group-item-inline settings-group-item-inline-right"
                                            Content="{l:Localization ButtonSearchFile}" />
						            <TextBox Classes="settings-group-item-inline-left"
                                             Text="{Binding Path=SettingsViewModel.PathToData}"/>
                                </DockPanel>
                            </StackPanel>

                        </StackPanel>
                    </HeaderedContentControl>

                    <Separator />

                    <!-- Загруженные браузеры -->

                    <HeaderedContentControl Classes="settings-group">
                        <HeaderedContentControl.Header>
							<TextBlock Text="{l:Localization LabelSettingsHeaderInstalledBrowsers}"
                                       Classes="settings-group-header" />
                        </HeaderedContentControl.Header>

                        <StackPanel Classes="settings-body">
                            <TextBlock Text="{l:Localization LabelSettingsDescriptionInstalledBrowsers}" 
                                Classes="settings-group-description"/>

                            <ItemsControl ItemsSource="{Binding Path=SettingsViewModel.Browsers}"
                                          ItemTemplate="{StaticResource SettingsBrowserTypesViewModel}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </HeaderedContentControl>

                    <Separator />

                    <!-- Настройки интерфейса -->

                    <HeaderedContentControl Classes="settings-group">
                        <HeaderedContentControl.Header>
							<TextBlock Text="{l:Localization LabelSettingsHeaderUserInterface}"
                                       Classes="settings-group-header" />
                        </HeaderedContentControl.Header>

						<StackPanel Classes="settings-body">
					        <TextBlock Text="{l:Localization LabelSettingsDescriptionUserInterface}"
                                       Classes="settings-group-description" />
                            <TextBlock Text="{l:Localization LabelSettingsLanguage}"
                                       Classes="settings-group-item" />
                            <ComboBox ItemsSource="{Binding Path=SettingsViewModel.Cultures}" SelectedItem="{Binding Path=SettingsViewModel.SelectedCulture}" />
                        </StackPanel>
                    </HeaderedContentControl>

                    <Separator />

                    <!-- Панель управления -->

                    <HeaderedContentControl Classes="settings-group">
                        <Button Content="{l:Localization ButtonSave}"
                                Command="{Binding Path=SettingsViewModel.SaveChangesCommand}" />
                    </HeaderedContentControl>

                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>

</Window>