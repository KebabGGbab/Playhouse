<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Playhouse.ViewModels.ViewModels"
        xmlns:localization="using:KebabGGbab.Avalonia.Extensions.Services.Localization"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Playhouse.UI.Views.BotConstructorWindow" x:FieldModifier="internal"
        x:DataType="vm:BotConstructorViewModel"
        Title="{localization:Localization WindowConstructorBotTitle}">
  
    <Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
            <ColumnDefinition MaxWidth="300" />
        </Grid.ColumnDefinitions>
    </Grid>

</Window>
