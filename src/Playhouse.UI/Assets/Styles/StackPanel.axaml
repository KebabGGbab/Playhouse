<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
    <Border Padding="20">
      <!-- Add Controls for Previewer Here -->
    </Border>
  </Design.PreviewWith>

  <Style Selector="StackPanel.first-group">
      <Setter Property="Orientation" Value="Vertical" />
	  <Setter Property="Margin" Value="0,0,0,0" />
  </Style>

  <Style Selector="StackPanel.middle-group">
      <Setter Property="Orientation" Value="Vertical" />
	  <Setter Property="Margin" Value="0,10,0,10" />
  </Style>

  <Style Selector="StackPanel.last-group">
      <Setter Property="Orientation" Value="Vertical" />
	  <Setter Property="Margin" Value="0,0,0,0" />
  </Style>

    <Style Selector="StackPanel.settings-body">
		<Setter Property="MaxWidth" Value="500" />
    </Style>

    <Style Selector="StackPanel.browser-event-settings">
		<Setter Property="Orientation" Value="Vertical" />
        <Setter Property="Spacing" Value="25" />
        <Setter Property="Margin" Value="20" />
    </Style>

    <Style Selector="StackPanel.browser-event-settings-item">
		<Setter Property="Orientation" Value="Vertical" />
        <Setter Property="Spacing" Value="8" />
    </Style>

</Styles>
