<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="ChateauGrayBrush" Color="{StaticResource ChateauGrayColor}" />
    <SolidColorBrush x:Key="DarkCharcoalBrush" Color="{StaticResource DarkCharcoalColor}" />
    <SolidColorBrush x:Key="GraphiteBlackBrush" Color="{StaticResource GraphiteBlackColor}" />
    <SolidColorBrush x:Key="SignalBlackBrush" Color="{StaticResource SignalBlackColor}" />

</ResourceDictionary>
