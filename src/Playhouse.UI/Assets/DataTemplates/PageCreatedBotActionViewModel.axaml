<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:l="https://github.com/KebabGGbab"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="using:Playhouse.ViewModels.ViewModels.BotActionViewModels">

    <DataTemplate x:Key="PageCreatedBotActionViewModel.Details" DataType="{x:Type vm:PageCreatedBotActionViewModel}">
    </DataTemplate>

    <DataTemplate x:Key="PageCreatedBotActionViewModel.Master" DataType="{x:Type vm:PageCreatedBotActionViewModel}">
        <TextBlock Text="{l:Localization PageCreatedBotActionViewModel_Master_Title}" />
    </DataTemplate>

</ResourceDictionary>
