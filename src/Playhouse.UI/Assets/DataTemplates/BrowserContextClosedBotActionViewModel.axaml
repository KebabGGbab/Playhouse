<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:l="https://github.com/KebabGGbab"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="using:Playhouse.ViewModels.ViewModels.BotActionViewModels">

    <DataTemplate x:Key="BrowserContextClosedBotActionViewModel.Details" DataType="{x:Type vm:BrowserContextClosedBotActionViewModel}">
		<StackPanel Classes="browser-event-settings">

			<StackPanel Classes="browser-event-settings-item">
				<TextBlock Classes="browser-event-settings-item" 
                           Text="{l:Localization BrowserContextClosedBotActionViewModel_Details_Reason}" />
                <TextBox Text="{Binding Path=Reason, Mode=TwoWay}" />
            </StackPanel>

        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="BrowserContextClosedBotActionViewModel.Master" DataType="{x:Type vm:BrowserContextClosedBotActionViewModel}">
        <TextBlock Text="{l:Localization BrowserContextClosedBotActionViewModel_Master_Title}"/>
    </DataTemplate>

</ResourceDictionary>
