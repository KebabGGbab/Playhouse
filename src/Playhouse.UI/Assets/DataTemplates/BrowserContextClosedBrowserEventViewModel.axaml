<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="using:Playhouse.ViewModels.ViewModels.EventBrowserViewModels">

    <DataTemplate x:Key="BrowserContextClosedBrowserEventViewModel" DataType="{x:Type vm:BrowserContextClosedBrowserEventViewModel}">
		<StackPanel Classes="browser-event-settings">
			<StackPanel Classes="browser-event-settings-item">
				<TextBlock Classes="browser-event-settings-item" 
                           Text="Причина закрытия:" />
                <TextBox Text="{Binding Path=Reason, Mode=TwoWay}" />
            </StackPanel>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
