<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:l="https://github.com/KebabGGbab"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="using:Playhouse.ViewModels.ViewModels.BotActionViewModels">

    <DataTemplate x:Key="PageGoToBotActionViewModel.Details" DataType="{x:Type vm:PageGoToBotActionViewModel}">
        <ScrollViewer Classes="browser-event-settings">
            <StackPanel Classes="browser-event-settings">

			    <StackPanel Classes="browser-event-settings-item">
				    <TextBlock Classes="browser-event-settings-item" 
                               Text="{l:Localization PageGoToBotActionViewModel_Details_NewUrl}" />
                    <TextBox Text="{Binding Path=Url, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Classes="browser-event-settings-item">
				    <TextBlock Classes="browser-event-settings-item" 
                               Text="{l:Localization PageGoToBotActionViewModel_Details_OldUrl}" />
                    <TextBox Text="{Binding Path=Referer, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Classes="browser-event-settings-item">
				    <TextBlock Classes="browser-event-settings-item" 
                               Text="{l:Localization PageGoToBotActionViewModel_Details_Timeout}" />
                    <NumericUpDown Classes="timeout"
                                   Value="{Binding Path=Timeout, Mode=TwoWay}" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </DataTemplate>

    <DataTemplate x:Key="PageGoToBotActionViewModel.Master" DataType="{x:Type vm:PageGoToBotActionViewModel}">
        <TextBlock Text="{l:Localization PageGoToBotActionViewModel_Master_Title}" />
    </DataTemplate>

</ResourceDictionary>
