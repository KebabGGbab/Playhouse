<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
    <Border Padding="20">
      <Button MinWidth="100" Content="Content" />
    </Border>
  </Design.PreviewWith>

    <Style Selector="Button">
		<Setter Property="CornerRadius" Value="6" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.box-action">
		<Setter Property="MinWidth" Value="100" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="20,25,20,0" />
    </Style>

    <Style Selector="Button.not-defined-size">
		<Setter Property="HorizontalAlignment" Value="Stretch" /> 
    </Style>

    <Style Selector="Button.settings-group-item-inline">
		<Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MaxWidth" Value="130" />
        <Setter Property="MinWidth" Value ="100" />
    </Style>

    <Style Selector="Button.settings-group-item-inline-right">
		<Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>

</Styles>
